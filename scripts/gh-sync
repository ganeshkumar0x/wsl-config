#!/usr/bin/env bash
# gh-sync

set -euo pipefail

ORG_NAME=""
TARGET_DIR="$HOME/projects"

if [[ -z "$ORG_NAME" ]]; then
    echo "Set ORG_NAME in this file." >&2
    exit 1
fi

if ! gh auth status >/dev/null 2>&1; then
    echo "Run 'gh auth login' first." >&2
    exit 1
fi

mkdir -p "$TARGET_DIR"
cd "$TARGET_DIR"

printf '1) Clone all repositories\n2) Pull all repositories\n'
read -r -p "Selection (1/2): " choice

case "$choice" in
    1)
        gh repo list "$ORG_NAME" --limit 1000 --json sshUrl --jq '.[].sshUrl' |
            while IFS= read -r repo; do
                git clone "$repo"
            done
        ;;
    2)
        for dir in */; do
            if [[ -d "$dir/.git" ]]; then
                echo "Updating $dir"
                git -C "$dir" pull --ff-only origin main
            fi
        done
        ;;
    *)
        echo "Invalid selection." >&2
        exit 1
        ;;
esac
